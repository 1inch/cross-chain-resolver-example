        {
            "files": ["scripts/**/*.js"],
            "rules": {
                "no-console": "off",
                "import/no-unresolved": "off",
                "import/no-commonjs": "off",
                "indent": "off",
                "comma-dangle": "off",
                "padding-line-between-statements": "off",
                "object-curly-spacing": "off",
                "quotes": "off",
                "semi": "off"
            }
        }
    ]
